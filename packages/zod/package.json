{
  "name": "@stream-schema/zod",
  "version": "0.1.0",
  "description": "Zod schema integration for @stream-schema/react",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsup src/index.ts --format cjs,esm --external react --external zod --external @stream-schema/core --external @stream-schema/react"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "@stream-schema/core": "^0.1.0",
    "@stream-schema/react": "^0.1.0"
  },
  "keywords": ["zod", "streaming", "ai", "llm", "react", "schema", "structured-output"],
  "license": "MIT",
  "author": "starkyru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starkyru/stream-schema.git",
    "directory": "packages/zod"
  },
  "homepage": "https://github.com/starkyru/stream-schema#readme",
  "publishConfig": {
    "access": "public"
  }
}
