{
  "name": "@stream-schema/core",
  "version": "0.1.0",
  "description": "Framework-agnostic partial JSON streaming parser and stream reader",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run"
  },
  "keywords": ["streaming", "json", "partial-json", "ai", "llm", "structured-output"],
  "license": "MIT",
  "author": "starkyru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starkyru/stream-schema.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/starkyru/stream-schema#readme",
  "publishConfig": {
    "access": "public"
  }
}
