{
  "name": "@stream-schema/react",
  "version": "0.1.0",
  "description": "React hooks and headless primitives for streaming structured AI output",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsup src/index.ts --format cjs,esm --external react --external @stream-schema/core",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@stream-schema/core": "^0.1.0"
  },
  "keywords": ["react", "streaming", "ai", "llm", "hooks", "structured-output"],
  "license": "MIT",
  "author": "starkyru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starkyru/stream-schema.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/starkyru/stream-schema#readme",
  "publishConfig": {
    "access": "public"
  }
}
