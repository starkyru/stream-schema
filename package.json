{
  "name": "stream-schema",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint packages/*/src/**/*.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "stream-schema/apps/demo/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "stream-schema/apps/demo/**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
